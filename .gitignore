.DS_Store

# Local virtualenvs and sandboxes
venv/
voice-agents-hack/

# Xcode local state
DerivedData/
build/
*.xcuserstate
*.xcscmblueprint
*.xccheckout
*.moved-aside
xcuserdata/
*.xcworkspace/xcuserdata/

# Keep only the vendored iOS framework from the local cactus workspace
cactus/*
!cactus/apple/
cactus/apple/*
!cactus/apple/cactus-ios.xcframework/
!cactus/apple/cactus-ios.xcframework/**

# Ignore large local model and tooling folders
cactus/weights/
cactus/venv/
cactus/.venv/
cactus/.git/
cactus/.gitmodules
